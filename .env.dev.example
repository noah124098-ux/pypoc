# Development environment secrets template.
# Copy to .env.dev and fill in your dev credentials.
# .env.dev is git-ignored; this example file is tracked.

APP_ENV=dev

# Angel One data-feed credentials (DATA-ONLY — never used for order placement)
ANGEL_ONE_API_KEY=dev_key_here
ANGEL_ONE_API_SECRET=dev_secret_here
ANGEL_ONE_CLIENT_CODE=dev_client_here
ANGEL_ONE_PASSWORD=dev_password_here
ANGEL_ONE_TOTP_SECRET=dev_totp_here

# Optional: Anthropic (EOD reviewer)
ANTHROPIC_API_KEY=

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
