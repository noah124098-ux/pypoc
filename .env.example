# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ---- Angel One SmartAPI (live market data) ----
# Get these from https://smartapi.angelbroking.com/ after creating an app
ANGEL_ONE_API_KEY=
ANGEL_ONE_API_SECRET=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
# TOTP secret string (the one shown when you enable TOTP for SmartAPI)
ANGEL_ONE_TOTP_SECRET=

# ---- Anthropic (EOD reviewer) ----
ANTHROPIC_API_KEY=

# ---- Telegram alerts (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Email (EOD report, optional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
