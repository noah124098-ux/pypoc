# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# === DATA FEED (Angel One SmartAPI — DATA-ONLY, never used for orders) ===
# Get these from https://smartapi.angelbroking.com/ after creating an app.
# These credentials are guarded at code level — placeOrder/modifyOrder/cancelOrder
# raise RuntimeError("...DATA-ONLY...") immediately after login.
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_API_SECRET=your_api_secret_here
ANGEL_ONE_CLIENT_CODE=your_client_code
ANGEL_ONE_PASSWORD=your_password
# TOTP secret string (the base32 seed shown when you enable TOTP for SmartAPI)
ANGEL_ONE_TOTP_SECRET=your_totp_secret_base32

# === LIVE BROKER (SEPARATE Angel One app — Phase 7, not yet active) ===
# Create a NEW Angel One API app with order permissions. NEVER reuse the data-feed credentials above.
# Leave blank until Phase 7 live-broker integration is implemented.
ANGEL_ONE_LIVE_API_KEY=
ANGEL_ONE_LIVE_CLIENT_CODE=
ANGEL_ONE_LIVE_PASSWORD=
ANGEL_ONE_LIVE_TOTP_SECRET=

# === AI / LLM ===
# Required for the EOD Claude reviewer (daily trade analysis + parameter suggestions).
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# === NOTIFICATIONS (optional) ===
# Telegram: create a bot via @BotFather and get the chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email (EOD report + halt alerts) — Gmail example shown; adjust for your provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# === ALTERNATIVE DATA FEED (Upstox — optional) ===
# Requires the upstox_api2 package. Leave blank if using Angel One.
UPSTOX_API_KEY=
UPSTOX_ACCESS_TOKEN=
