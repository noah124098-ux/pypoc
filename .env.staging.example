# Staging environment secrets template.
# Copy to .env.staging and fill in your staging credentials.
# .env.staging is git-ignored; this example file is tracked.

APP_ENV=staging

# Angel One data-feed credentials (DATA-ONLY — never used for order placement)
ANGEL_ONE_API_KEY=staging_key_here
ANGEL_ONE_API_SECRET=staging_secret_here
ANGEL_ONE_CLIENT_CODE=staging_client_here
ANGEL_ONE_PASSWORD=staging_password_here
ANGEL_ONE_TOTP_SECRET=staging_totp_here

# Optional: Anthropic (EOD reviewer)
ANTHROPIC_API_KEY=

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
