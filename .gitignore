# --- Secrets (never commit) ---
.env
.env.*
!.env.example
!.env.dev.example
!.env.staging.example
*.pem
*.key
secrets/
credentials.json
deploy/.htpasswd

# --- Local tool config ---
# Track .claude/memory + shared operating files; NOT per-machine state.
.claude/*
!.claude/memory/
!.claude/MASTER_WORKER.md
!.claude/workflows/
!.claude/settings.json
.claude/settings.local.json
.idea/
.vscode/
*.swp

# --- Python ---
*.pyc
__pycache__/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/
.coverage
htmlcov/

# --- Node / Frontend ---
node_modules/
frontend/node_modules/

# --- Databases & local stores ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Generated data caches (regenerate from source) ---
data/backtest_cache/
data/bhavcopy_cache/
data/cache/
data/ticks/
data/snapshot.json
*.parquet

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
Thumbs.db

# --- Reports (regenerated) ---
reports/
