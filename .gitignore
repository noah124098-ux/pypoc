# --- Secrets (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials.json

# --- Local tool config ---
# Track .claude/memory (project-scoped Claude Code memory ships with the repo)
# but NOT settings.local.json or other per-machine state.
.claude/*
!.claude/memory/
.claude/settings.local.json
.idea/
.vscode/
*.swp

# --- Python ---
*.pyc
__pycache__/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# --- Databases & local stores ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Generated data caches (regenerate from source) ---
data/backtest_cache/
data/bhavcopy_cache/
data/cache/
data/ticks/
data/snapshot.json
*.parquet

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
Thumbs.db

# --- Reports (regenerated) ---
reports/
